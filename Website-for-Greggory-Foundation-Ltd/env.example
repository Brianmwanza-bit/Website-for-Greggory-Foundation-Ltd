# Google Cloud Configuration
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./config/gcp-service-account.json

# Storage Buckets
STORAGE_BUCKET_MEDIA=gregory-foundation-media
STORAGE_BUCKET_BACKUPS=gregory-foundation-backups

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_secure_password
DB_NAME=greggory_foundation_db

# App Configuration
NODE_ENV=development
PORT=3000

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Email Configuration (if needed)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM="Gregory Foundation <noreply@gregoryfoundation.com>"

# Frontend URL (for CORS and email links)
FRONTEND_URL=http://localhost:3000

# Session Secret (for express-session)
SESSION_SECRET=your_session_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15*60*1000  // 15 minutes
RATE_LIMIT_MAX=100  // limit each IP to 100 requests per windowMs
